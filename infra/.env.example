# Corn Hub — Docker Environment
# Copy to .env and fill in actual values

# ── OpenAI (for mem9 embeddings) ─────────────
OPENAI_API_KEY=sk-xxx

# ── Gemini (alternative embeddings) ──────────
GEMINI_API_KEY=

# ── MCP API Keys (comma-separated) ───────────
# Generate keys from the Dashboard → API Keys page
MCP_API_KEYS=

# ── Embedding Model ──────────────────────────
MEM9_EMBEDDING_MODEL=text-embedding-3-small

# ── Build metadata (auto-populated by CI) ────
COMMIT_SHA=dev
BUILD_DATE=
